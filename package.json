{
  "name": "sakekeep",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "generate-routes": "tsr generate",
    "build": "vite build",
    "preview": "vite preview",
    "format": "RAYON_NUM_THREADS=2 oxfmt --write .",
    "format:check": "RAYON_NUM_THREADS=2 oxfmt --check .",
    "lint": "RAYON_NUM_THREADS=2 oxlint --deny-warnings .",
    "typecheck": "tsc --noEmit",
    "test": "node node_modules/vitest/vitest.mjs run",
    "test:e2e": "node node_modules/@playwright/test/cli.js test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "bun run scripts/seed.ts",
    "storage:cleanup": "bun run scripts/cleanup-orphans.ts",
    "setup:icc": "bun run scripts/fetch-icc.ts",
    "setup": "bun install && bun run setup:icc && bun run services:up && bun run db:migrate && bun run db:seed",
    "services:up": "docker compose up -d --wait",
    "services:down": "docker compose down",
    "health": "bun run scripts/health.ts",
    "verify": "bun run format:check && bun run lint && bun run typecheck && bun run test && bun run test:e2e && bun run build && docker compose config --quiet"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1090.0",
    "@aws-sdk/lib-storage": "^3.1090.0",
    "@base-ui/react": "^1.6.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/source-serif-4": "^5.2.9",
    "@pdf-lib/fontkit": "^1.1.1",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/router-plugin": "^1.132.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "fabric": "7",
    "idb": "^8.0.3",
    "lucide-react": "^0.545.0",
    "next-themes": "^0.4.6",
    "pdf-lib": "^1.17.1",
    "pg": "^8.22.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "shadcn": "^4.13.1",
    "sharp": "^0.35.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/devtools-vite": "latest",
    "@tanstack/router-cli": "^1.132.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "axe-core": "^4.12.1",
    "drizzle-kit": "^0.31.10",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^28.1.0",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.0",
    "vitest": "^4.1.5"
  },
  "packageManager": "bun@1.3.9",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  }
}
